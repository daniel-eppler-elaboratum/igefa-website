# =============================================================
# ENVIRONMENT VARIABLES — TEMPLATE
# Kopiere diese Datei zu .env und fuelle die Werte aus.
# NIEMALS echte Werte in .env.example eintragen!
# Die echte .env wird NICHT committet (siehe .gitignore).
# =============================================================

# Storyblok Preview-Token (Settings -> Access Tokens -> "Preview")
# Wird vom Frontend genutzt, um Inhalte (auch Entwuerfe) zu laden.
STORYBLOK_PREVIEW_TOKEN=

# Storyblok Space-ID (Settings -> General)
STORYBLOK_SPACE_ID=

# HINWEIS: Der Storyblok MANAGEMENT-Token gehoert NICHT in diese Datei.
# Er lebt ausschliesslich in der MCP-Konfiguration (.mcp.json, gitignored).
