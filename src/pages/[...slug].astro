---
import { useStoryblokApi, getPayload } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import Layout from '../layouts/Layout.astro';

const slug = Astro.params.slug ?? 'home';

// Im Visual Editor liefert die Middleware die ungespeicherten Live-Daten
// ueber Astro.locals. So sieht der Redakteur Aenderungen sofort.
const payload = await getPayload({ locals: Astro.locals });
let story = payload.story ?? null;

// Normaler Aufruf (kein Editor): Story aus der Content Delivery API laden.
// version 'draft', damit auch ungespeicherte/unveroeffentlichte Inhalte
// in der Vorschau sichtbar sind.
if (!story) {
  try {
    const storyblokApi = useStoryblokApi();
    const { data } = await storyblokApi.get(`cdn/stories/${slug}`, {
      version: 'draft',
    });
    story = data.story;
  } catch (error) {
    // Storyblok wirft bei nicht existierender Story einen 404. Sauber abfangen,
    // damit ein fehlender Inhalt die Seite nicht mit einem 500 abstuerzen laesst.
    console.error(
      `Story "${slug}" konnte nicht geladen werden:`,
      error instanceof Error ? error.message : error,
    );
    story = null;
  }
}

// Interne Daten-Stories (z. B. `config` = Header/Navigation, `footer`) sind keine
// Seiten, sondern Datencontainer (werden in Layout.astro geladen). Direkt aufgerufen
// (z. B. /config) sollen sie eine 404-Seite zeigen statt eines Render-Fehlers
// ("No component found for blok site_config").
const INTERNAL_CONTENT_TYPES = ['site_config', 'site_footer'];
if (story && INTERNAL_CONTENT_TYPES.includes(story.content?.component)) {
  story = null;
}

// Kein Inhalt gefunden -> saubere 404-Seite (mit Navigation) statt Absturz.
if (!story) {
  Astro.response.status = 404;
}
---

{story ? (
  <Layout title={story.name}>
    <StoryblokComponent blok={story.content} />
  </Layout>
) : (
  <Layout title="Seite nicht gefunden">
    <main class="mx-auto max-w-3xl px-md py-xl text-center">
      <p class="text-sm font-semibold text-accent">Fehler 404</p>
      <h1 class="mt-sm text-3xl font-bold">Seite nicht gefunden</h1>
      <p class="mt-md text-muted">
        Die Seite „{slug}" gibt es (noch) nicht. Vielleicht hilft die Navigation oben weiter.
      </p>
      <a
        href="/"
        class="mt-lg inline-block rounded-base bg-brand px-lg py-sm font-semibold text-surface hover:bg-brand-dark hover:no-underline"
      >
        Zur Startseite
      </a>
    </main>
  </Layout>
)}
