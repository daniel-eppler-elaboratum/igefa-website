---
import { storyblokEditable } from '@storyblok/astro';
import { resolveNavLink } from '../lib/navigation';

// blok = Storyblok-Block "top_bar_link" (ein Button in der oberen Leiste).
const { blok } = Astro.props;
const href = resolveNavLink(blok.link);

// Fertige Icons (Feather-Stil) je Auswahl. So muss die Redaktion nichts hochladen.
const iconPaths: Record<string, string> = {
  phone:
    '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.81.36 1.6.7 2.34a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.74.34 1.53.57 2.34.7A2 2 0 0 1 22 16.92z"/>',
  mail: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  megaphone: '<path d="M3 11l18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/>',
  cart: '<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>',
};
const iconSvg = iconPaths[blok.icon] ?? '';
---

<a
  {...storyblokEditable(blok)}
  href={href}
  class="inline-flex items-center gap-xs border-l border-brand bg-brand-dark px-md py-xs text-sm font-semibold text-surface transition-colors first:border-l-0 hover:bg-brand hover:text-surface hover:no-underline"
>
  {iconSvg && (
    <svg
      class="h-4 w-4"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      set:html={iconSvg}
    />
  )}
  {blok.label}
</a>
