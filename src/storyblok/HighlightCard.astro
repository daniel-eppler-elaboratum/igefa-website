---
import { storyblokEditable } from '@storyblok/astro';
import { resolveNavLink } from '../lib/navigation';

// blok = "highlight_card" — Highlight (Bild, Kategorie-Label, Titel; ganz klickbar).
const { blok } = Astro.props;
const href = resolveNavLink(blok.link);
const imageUrl = blok.image?.filename ?? '';
---

<a {...storyblokEditable(blok)} href={href} class="group block hover:no-underline" style={'background-color:' + blok.color}>
  {imageUrl && (
    <div class="overflow-hidden rounded-lg">
      <img
        src={imageUrl}
        alt={blok.image?.alt ?? ''}
        class="aspect-[16/9] w-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    </div>
  )}
  {blok.category_label && (
    <div class="mt-md text-sm font-semibold uppercase tracking-wide text-brand">{blok.category_label}</div>
  )}
  {blok.title && <h3 class="mt-xs text-xl font-bold text-heading group-hover:text-brand">{blok.title}</h3>}
</a>
