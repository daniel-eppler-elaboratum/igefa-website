---
import { storyblokEditable } from '@storyblok/astro';
import { resolveNavLink } from '../lib/navigation';

// blok = "social_link" — runder Social-Icon-Button (Plattform-Glyph + Link).
const { blok } = Astro.props;
const href = resolveNavLink(blok.link);
const platform: string = blok.platform ?? '';

const labels: Record<string, string> = {
  instagram: 'Instagram',
  facebook: 'Facebook',
  xing: 'Xing',
  linkedin: 'LinkedIn',
  youtube: 'YouTube',
};

// Kompakte Marken-Glyphen (Outline-Stil).
const icons: Record<string, string> = {
  instagram:
    '<rect x="3" y="3" width="18" height="18" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>',
  facebook: '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>',
  linkedin:
    '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
  youtube:
    '<path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="currentColor"/>',
  xing: '<path d="M7 6l3 5-4 7h3l4-7-3-5zm9-3l-6 10 4 7h3l-4-7 6-10z"/>',
};
const iconSvg = icons[platform] ?? '';
---

{iconSvg && (
  <a
    {...storyblokEditable(blok)}
    href={href}
    aria-label={labels[platform] ?? platform}
    class="flex h-11 w-11 items-center justify-center rounded-full border border-surface/40 text-surface transition-colors hover:border-surface hover:bg-surface/10 hover:no-underline"
  >
    <svg
      class="h-5 w-5"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      set:html={iconSvg}
    />
  </a>
)}
